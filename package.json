{
  "name": "promptly",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "react-router dev",
    "build": "NODE_OPTIONS='--max-old-space-size=4096' react-router build",
    "cf-typegen": "wrangler types",
    "deploy": "bun run build && wrangler deploy",
    "prerender": "bun run scripts/prerender-landing.ts",
    "postinstall": "bun run cf-typegen",
    "preview": "bun run build && vite preview",
    "typecheck": "bun run cf-typegen && react-router typegen && tsc -b",
    "lint": "bunx biome check .",
    "lint:fix": "bunx biome check --write .",
    "db:generate": "bunx @better-auth/cli generate --output ./migrations/auth-schema.ts -y && bunx drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply promptly --local",
    "db:migrate:prod": "wrangler d1 migrations apply promptly --remote",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
