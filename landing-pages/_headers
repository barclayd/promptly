# Homepage - always revalidate via ETag (instant invalidation on deploy)
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Fingerprinted assets (JS, CSS) - cache aggressively (1 year)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Font files - cache aggressively (1 year, immutable)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Favicon - cache for 1 week
/favicon.ico
  Cache-Control: public, max-age=604800

# Default for other static files
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
