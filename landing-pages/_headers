# Homepage - always revalidate via ETag (instant invalidation on deploy)
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate

# Fingerprinted assets (JS, CSS) - cache aggressively (1 year)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Font files - cache aggressively (1 year, immutable)
/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# Favicon - cache for 1 week
/favicon.ico
  Cache-Control: public, max-age=604800

# Default for other static files
# `frame-ancestors` (CSP) replaces the deprecated X-Frame-Options. Only
# danbarclay.dev (and localhost during dev) may embed this site in a frame;
# everywhere else is still blocked.
/*
  X-Content-Type-Options: nosniff
  Content-Security-Policy: frame-ancestors 'self' https://danbarclay.dev https://*.danbarclay.dev http://localhost:* http://127.0.0.1:*
  Referrer-Policy: strict-origin-when-cross-origin
